# ────────────────────────────────────────────────────────
# YesCab Backend — Environment Configuration TEMPLATE
# Copy this file to .env and fill in your real values.
# NEVER commit the .env file to version control.
# ────────────────────────────────────────────────────────

# Django Core
SECRET_KEY=
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (sqlite3 for dev, postgresql for production)
DB_ENGINE=sqlite3
DB_NAME=db.sqlite3
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=

# Email (Resend in production, SMTP/Console in development)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
RESEND_API_KEY=re_your_resend_api_key_here
DEFAULT_FROM_EMAIL=onboarding@resend.dev

# Admin notification email
ADMIN_EMAIL=

# CORS — comma-separated origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Google OAuth2
GOOGLE_OAUTH2_CLIENT_ID=

# Frontend URL (for email links: verification, password reset)
FRONTEND_URL=http://localhost:5173

# Throttle rates (DRF format: requests/period)
# Dev: relaxed   |  Production: strict
ANON_THROTTLE_RATE=20/min
USER_THROTTLE_RATE=60/min
AUTH_THROTTLE_RATE=20/min
# Production recommendation: AUTH_THROTTLE_RATE=5/15m
