# ────────────────────────────────────────────────────────
# YesCab Backend — Environment Configuration TEMPLATE
# Copy this file to .env and fill in your real values.
# NEVER commit the .env file to version control.
# ────────────────────────────────────────────────────────

# Django Core
SECRET_KEY=
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (sqlite3 for dev, postgresql for production)
DB_ENGINE=sqlite3
DB_NAME=db.sqlite3
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=

# Email (SMTP)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=YesCab <no-reply@yescab.com>

# CORS — comma-separated origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Google OAuth2
GOOGLE_OAUTH2_CLIENT_ID=
